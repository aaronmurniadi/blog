#let journal = (
  institution: "Typst University",
  journal: "Typst Type Review",
  year: 2013,
  month: "July-September",
  copyright: "© 2026 Typst University",
  volume: 1,
  number: 1,
  articles: (article-1, article-2, article-3, article-4, article-5, article-6, article-7),
)

#show: typearea.with(
  two-sided: false,
  width: 148mm,
  height: 210mm,
)

#set text(
  size: 11pt,
  number-type: "lining",
  lang: "en",
)

#set par(
  first-line-indent: (amount: 1.5em, all: false),
  leading: 0.65em,
  spacing: 0.65em,
  justify: true,
  justification-limits: (
    tracking: (max: 0.1em, min: -0.015em),
  ),
)

#let cover-page = {
  show: typearea.with(
    two-sided: false,
    div: 18,
    binding-correction: 0mm,
    header-include: false,
    footer-include: false,
    header-height: 0em,
    footer-height: 0em,
    footer: [#text(style: "italic")[#journal.copyright]],
  )


  grid(
    columns: (1fr, 1fr, 1fr),
    rows: (5em, 5em),
    align: (left, center, right),
    [VOLUME #journal.volume], [ISSUE #journal.number], [#journal.month #journal.year],
    grid.cell(colspan: 3)[
      #set text(size: 3em, weight: "bold", style: "italic")
      #set text(tracking: 0.05em)
      #journal.journal
    ],
  )

  grid(
    columns: (4em, 1fr, 1em),
    align: (left, left),
    [],
    [
      #set par(justify: false, first-line-indent: 0em)
      #for article in journal.articles {
        [
          #par[
            #text(weight: "bold")[#article.title]
          ]

          #par[
            #h(1em) #text(style: "italic")[
              #article.authors.map(author => author.name).join(", ")
            ]
          ]

          #v(0.5em)
        ]
      }
    ],
  )
}

#let article-page(article) = {
  show heading.where(level: 1): it => {
    set text(size: 14pt, weight: "bold")
    align(center)[
      #block(width: 95%, [#v(2em) #it #v(2em)])
    ]
  }
  show heading.where(level: 2): set text(size: 12pt, weight: "semibold")
  show heading.where(level: 3): set text(size: 11pt, weight: "regular", style: "italic")

  show: typearea.with(
    two-sided: false,
    div: 15,
    binding-correction: 0mm,
    header-include: true,
    footer-include: false,
    header-height: 0em,
    header: context {
      let matches = query(<article-title>)
      let current = counter(page).get()
      let has-article-title = matches.any(
        m => counter(page).at(m.location()) == current,
      )
      if counter(page).get().first() > 1 {
        if calc.odd(counter(page).get().first()) {
          if not has-article-title {
            h(1fr)
            article.short-title
            h(1fr)
          }
        } else {
          if not has-article-title {
            h(1fr)
            article.authors.map(author => author.name).join(", ")
            h(1fr)
          }
        }
      }
    },
  )
  set par(justify: false)

  [= #article.title <article-title>]

  v(1em)

  par()[
    #article.authors.map(author => author.name).join(", ")
  ]

  v(1em)

  set par(justify: true)

  par()[#article.abstract]

  v(1em)
  article.body
}


#let body = {
  for article in journal.articles {
    article-page(article)
    pagebreak()
  }
}

#cover-page


#counter(page).update(1)

#body
